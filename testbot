#!/usr/bin/env bash
# Usage: ./testbot [URL]
# If URL is not provided, set TESTBOT_URL env var or edit the default below.

URL="${1:-${TESTBOT_URL:-http://localhost/}}"

USER_AGENT_FACEBOOK="facebookexternalhit/1.1 (+http://www.facebook.com/externalhit_uatext.php)"
USER_AGENT_META="meta-externalagent/1.1 (+https://developers.facebook.com/docs/sharing/webmasters/crawler)"

REQUEST_COUNT=5
SLEEP_INTERVAL=1

send_requests() {
    local ua="$1"
    echo "=== Testing with: $ua ==="
    for ((i=1; i<=REQUEST_COUNT; i++)); do
        RESPONSE=$(curl -s -A "$ua" -w "%{http_code}" -o /dev/null "$URL")
        echo "  Request $i → HTTP $RESPONSE"
        sleep $SLEEP_INTERVAL
    done
    echo ""
}

echo "Target: $URL"
echo ""
send_requests "$USER_AGENT_FACEBOOK"
send_requests "$USER_AGENT_META"
